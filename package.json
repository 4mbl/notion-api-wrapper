{
  "name": "notion-api-wrapper",
  "version": "6.0.0",
  "description": "Zero dependency Notion API client",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "naw": "dist/cli/entry.js"
  },
  "author": "4mbl",
  "license": "MIT",
  "homepage": "https://github.com/4mbl/notion-api-wrapper#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/4mbl/notion-api-wrapper"
  },
  "keywords": [
    "notion",
    "notion api",
    "notion-api",
    "notion-api-wrapper",
    "notion-client",
    "naw",
    "ntn"
  ],
  "files": [
    "dist/*"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "eslint",
    "format:write": "prettier --write ./src/**/*.ts",
    "format:check": "prettier --check ./src/**/*.ts",
    "publish:beta": "pnpm run build && changeset publish",
    "publish:stable": "pnpm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.2.0",
    "dotenv": "^17.2.0",
    "eslint": "^10.1.0",
    "globals": "^17.0.0",
    "prettier": "^3.6.2",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.38.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vitest": "^4.0.3"
  },
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=20"
  }
}
